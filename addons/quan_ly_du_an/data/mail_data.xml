<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cấu hình Outgoing Mail Server cho Gmail -->
        <record id="ir_mail_server_gmail" model="ir.mail_server">
            <field name="name">Gmail SMTP (Nhóm 9)</field>
            <field name="smtp_host">smtp.gmail.com</field>
            <field name="smtp_port">465</field>
            <field name="smtp_encryption">ssl</field>
            <field name="sequence">10</field>
        </record>
    </data>

    <data>
        <!-- Mẫu Email Thông báo Giao việc -->
        <record id="email_template_task_assignment" model="mail.template">
            <field name="name">Thông báo Giao việc mới</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="subject">🔔 Công việc mới: {{ object.name }}</field>
            <field name="email_to">{{ ','.join(object.nhan_vien_ids.mapped('work_email')) }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Chào bạn,
                        <br/><br/>
                        Bạn vừa được giao một công việc mới trong dự án <strong><t t-out="object.project_id.name or ''"/></strong>.
                        <br/><br/>
                        <strong>Tên công việc:</strong> <t t-out="object.name or ''"/><br/>
                        <strong>Hạn chót:</strong> <t t-out="object.date_deadline or 'Chưa xác định'"/><br/>
                        <strong>Mô tả:</strong> <t t-out="object.description or 'Không có mô tả'"/>
                        <br/><br/>
                        Vui lòng kiểm tra và thực hiện đúng tiến độ.
                        <br/><br/>
                        Trân trọng,
                        <br/>
                        Hệ thống Quản lý Dự án
                    </p>
                </div>
            </field>
        </record>
        <!-- Mẫu Email Nhắc nhở Hạn chót -->
        <record id="email_template_task_deadline_reminder" model="mail.template">
            <field name="name">Nhắc nhở hạn chót công việc</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="subject">⚠️ Nhắc nhở: Công việc "{{ object.name }}" sắp đến hạn!</field>
            <field name="email_to">{{ ','.join(object.nhan_vien_ids.mapped('work_email')) }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Chào bạn,
                        <br/><br/>
                        Đây là thông báo nhắc nhở công việc <strong><t t-out="object.name or ''"/></strong> của bạn sẽ đến hạn vào <strong>ngày mai (<t t-out="object.date_deadline or ''"/>)</strong>.
                        <br/><br/>
                        <strong>Dự án:</strong> <t t-out="object.project_id.name or ''"/><br/>
                        <strong>Tiến độ dự án:</strong> <t t-out="round(object.project_id.progress, 2)"/>%
                        <br/><br/>
                        Vui lòng kiểm tra và hoàn thành công việc đúng thời hạn.
                        <br/><br/>
                        Trân trọng,
                        <br/>
                        Hệ thống Tự động nhắc việc
                    </p>
                </div>
            </field>
        </record>

        <!-- Scheduled Action (Cron) chạy hàng ngày -->
        <record id="ir_cron_task_deadline_reminder" model="ir.cron">
            <field name="name">Dự án: Nhắc nhở hạn chót công việc hàng ngày</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_deadline_reminders()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="doall" eval="False"/>
        </record>
    </data>
</odoo>
