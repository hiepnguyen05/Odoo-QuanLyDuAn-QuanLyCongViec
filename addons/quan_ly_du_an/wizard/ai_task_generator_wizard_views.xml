<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ai_task_generator_wizard_form" model="ir.ui.view">
        <field name="name">ai.task.generator.wizard.form</field>
        <field name="model">ai.task.generator.wizard</field>
        <field name="arch" type="xml">
            <form string="Check &amp; Edit Gợi ý Của AI" class="o_form_project_tasks">
                <sheet>
                    <div class="oe_title" style="margin-bottom: 15px;">
                        <p class="text-muted" style="font-size: 14px;">
                            Hãy xem qua và chỉnh sửa lại các công việc nháp do AI tạo ra và Xác nhận để lưu vào hệ thống.
                        </p>
                    </div>
                    <group>
                        <field name="project_id" readonly="1" invisible="1"/>
                        <field name="thanh_vien_ids" invisible="1"/>
                    </group>
                    <field name="line_ids">
                        <tree editable="bottom" create="1" delete="1">
                            <field name="is_selected" widget="boolean_toggle"/>
                            <field name="name" string="Tên Công việc"/>
                            <field name="nhan_vien_ids" string="Người thực hiện" 
                                   widget="many2many_tags" 
                                   options="{'no_create': True}" 
                                   domain="[('id', 'in', parent.thanh_vien_ids)]"/>
                            <field name="description" string="Mô tả" optional="hide"/>
                        </tree>
                    </field>
                </sheet>
                <footer>
                    <button string="Xác nhận Sinh Công việc" name="action_confirm_create" type="object" class="btn-primary" icon="fa-magic"/>
                    <button string="Hủy bỏ" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
