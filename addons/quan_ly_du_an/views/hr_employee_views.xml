<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Form View: Mở rộng Form Nhân viên -->
    <record id="view_employee_form_inherit" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.quan_ly_du_an</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            
            <!-- Ẩn các trường mặc định của Odoo bị trùng lặp -->
            <xpath expr="//field[@name='identification_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='children']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            
            <!-- 1. Đưa thông tin CCCD vào nhóm trong tab Thông tin cá nhân -->
            <xpath expr="//page[@name='personal_information']/group/group[@name='has_work_permit']" position="before">
                <group string="Thông tin lý lịch (CCCD)">
                    <field name="so_cccd" placeholder="VD: 001234567890"/>
                    <field name="ngay_cap"/>
                    <field name="noi_cap" placeholder="VD: Cục Cảnh sát ĐKQL cư trú..."/>
                    <field name="que_quan" placeholder="VD: Hà Nội"/>
                    <field name="tuoi" readonly="1"/>
                </group>
            </xpath>
            
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_employee_tasks" type="object" class="oe_stat_button" icon="fa-tasks">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Công việc</span>
                        <span class="o_stat_value"><field name="task_done_count"/></span>
                    </div>
                </button>
            </xpath>

            <!-- 2. Đưa ds Gia đình và Quá trình công tác xuống phía dưới cùng của tab Thông tin cá nhân -->
            <xpath expr="//page[@name='personal_information']/group" position="after">
                <separator string="Gia đình"/>
                <field name="family_ids">
                    <tree editable="bottom">
                        <field name="name"/>
                        <field name="relationship"/>
                        <field name="birth_date"/>
                        <field name="is_dependent"/>
                    </tree>
                </field>
                
                <separator string="Quá trình công tác"/>
                <field name="work_history_ids">
                    <tree editable="bottom" default_order="date_start desc">
                        <field name="company_name"/>
                        <field name="position"/>
                        <field name="date_start"/>
                        <field name="date_end"/>
                    </tree>
                </field>
            </xpath>

            <!-- 3. Thêm tab Hiệu suất công việc (Mức 2) -->
            <xpath expr="//notebook" position="inside">
                <page name="project_performance" string="Hiệu suất dự án">
                    <group>
                        <group string="Thống kê KPI">
                            <field name="kpi_average" widget="progressbar"/>
                            <field name="task_done_count"/>
                            <field name="task_late_count" decoration-danger="task_late_count > 0"/>
                        </group>
                        <group string="Phân tích">
                            <div class="alert alert-info" role="alert" colspan="2">
                                <i class="fa fa-info-circle"></i> 
                                Dữ liệu này được tổng hợp tự động từ tất cả các dự án mà nhân viên này tham gia.
                                Điểm KPI trung bình dựa trên thang điểm 100 (A=100, B=80, C=60, D=40).
                            </div>
                        </group>
                    </group>
                </page>
            </xpath>
            
        </field>
    </record>
    
    <!-- Tree View: Mở rộng Tree View Nhân viên -->
    <record id="view_employee_tree_inherit" model="ir.ui.view">
        <field name="name">hr.employee.tree.inherit.quan_ly_du_an</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_tree"/>
        <field name="arch" type="xml">
            
            <!-- Ẩn cột job_id mặc định vì nó là thẻ link (Many2one), User thường dùng job_title (Char) -->
            <xpath expr="//field[@name='job_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            
            <xpath expr="//field[@name='job_id']" position="after">
                <field name="job_title" string="Vị trí công việc" optional="show"/>
            </xpath>
            
            <xpath expr="//field[@name='job_id']" position="after">
                <field name="so_cccd" optional="show"/>
                <field name="que_quan" optional="hide"/>
                <field name="tuoi" optional="hide"/>
            </xpath>
            
            <!-- Ẩn các cột Hoạt động kế tiếp (Activity) -->
            <xpath expr="//field[@name='activity_ids']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='activity_user_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='activity_date_deadline']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            
        </field>
    </record>
    
    <!-- Search View: Mở rộng Search View -->
    <record id="view_employee_filter_inherit" model="ir.ui.view">
        <field name="name">hr.employee.search.inherit.quan_ly_du_an</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_filter"/>
        <field name="arch" type="xml">
            
            <xpath expr="//field[@name='name']" position="after">
                <field name="so_cccd" string="Số CCCD"/>
                <field name="que_quan" string="Quê quán"/>
            </xpath>
            
            <xpath expr="//filter[@name='inactive']" position="after">
                <separator/>
                <filter string="Nhân viên trẻ (&lt; 30 tuổi)" name="young_employees" 
                        domain="[('birthday', '&gt;=', (context_today() - relativedelta(years=30)).strftime('%Y-%m-%d'))]"/>
                <filter string="Nhân viên trung niên (30-50 tuổi)" name="middle_age_employees" 
                        domain="[('birthday', '&lt;', (context_today() - relativedelta(years=30)).strftime('%Y-%m-%d')), 
                                 ('birthday', '&gt;=', (context_today() - relativedelta(years=50)).strftime('%Y-%m-%d'))]"/>
            </xpath>
            
            <xpath expr="//filter[@name='group_manager']" position="after">
                <filter string="Quê quán" name="group_que_quan" context="{'group_by': 'que_quan'}"/>
            </xpath>
            
        </field>
    </record>

    <!-- Kế thừa Action để đổi mặc định thành giao diện List (tree) -->
    <record id="hr.open_view_employee_list_my" model="ir.actions.act_window">
        <field name="view_mode">tree,kanban,form,activity</field>
    </record>

</odoo>
