<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Form View: Mở rộng Form Công việc -->
    <record id="view_task_form_inherit" model="ir.ui.view">
        <field name="name">project.task.form.inherit.quan_ly_cong_viec</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='allow_subtasks']" position="before">
                <field name="company_id" invisible="1"/>
                <field name="project_id" invisible="1"/>
                <field name="parent_id" invisible="1"/>
            </xpath>
            
            <xpath expr="//field[@name='user_ids']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='user_ids']" position="after">
                <field name="nhan_vien_ids" widget="many2many_tags" options="{'no_create': True}" string="Nhân viên HRM"/>
                <field name="completion_percentage" widget="progressbar"/>
            </xpath>
            
            <xpath expr="//field[@name='date_deadline']" position="before">
                <field name="planned_date_begin" string="Ngày bắt đầu"/>
            </xpath>

            <xpath expr="//group" position="after">
                <group string="Đánh giá kết quả (KPI)" name="kpi_data" 
                       attrs="{'invisible': [('date_completed', '=', False)]}">
                    <group>
                        <field name="date_completed"/>
                        <field name="kpi_rating" widget="priority"/>
                    </group>
                    <group>
                        <div class="alert alert-info" role="alert" style="margin-bottom: 0px;" 
                             attrs="{'invisible': [('kpi_rating', '=', False)]}">
                            <strong>Cách tính:</strong> KPI được tự động xếp loại khi bạn chuyển công việc sang trạng thái Hoàn thành.
                        </div>
                    </group>
                </group>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page name="subtasks" string="Công việc con (Subtasks)">
                    <field name="child_ids" context="{'default_project_id': project_id, 'default_parent_id': id}">
                        <tree editable="bottom">
                            <field name="company_id" invisible="1"/>
                            <field name="project_id" invisible="1"/>
                            <field name="name" string="Tên Subtask"/>
                            <field name="nhan_vien_ids" widget="many2many_tags" string="Người thực hiện"/>
                            <field name="date_deadline" string="Hạn chót"/>
                            <field name="stage_id" string="Trạng thái"/>
                        </tree>
                    </field>
                </page>
                <page name="ai_guidance" string="Hướng dẫn AI &amp; Checklist">
                    <group>
                        <div class="oe_title" style="margin-bottom: 20px;">
                            <label for="task_summary" string="Tóm tắt nhanh bằng AI"/>
                            <div class="d-flex align-items-center">
                                <field name="task_summary" placeholder="AI sẽ tóm tắt nội dung tại đây..." class="flex-grow-1"/>
                                <button name="action_summarize_task_ai" 
                                        type="object" 
                                        string="Tóm tắt bằng AI" 
                                        class="btn-primary ms-2" 
                                        help="Bấm để AI tóm tắt nội dung mô tả công việc"/>
                            </div>
                        </div>
                    </group>
                    <group>
                        <group string="Quy trình thực hiện (SOP)">
                            <field name="ai_sop" nolabel="1" placeholder="AI sẽ viết quy trình ở đây..."/>
                        </group>
                        <group string="Danh sách kiểm tra">
                            <field name="checklist_ids" nolabel="1">
                                <tree editable="bottom">
                                    <field name="is_done" widget="boolean_toggle"/>
                                    <field name="name"/>
                                </tree>
                            </field>
                        </group>
                    </group>
                </page>
            </xpath>
            
        </field>
    </record>
    
    <record id="view_task_search_inherit" model="ir.ui.view">
        <field name="name">project.task.search.inherit.quan_ly_cong_viec</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_search_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="project_id" string="Dự án"/>
                <field name="nhan_vien_ids" string="Nhân viên"/>
            </xpath>
            <xpath expr="//filter[@name='my_tasks']" position="after">
                <separator/>
                <filter string="Việc của tôi (HRM)" 
                        name="my_tasks_hrm" 
                        domain="[('nhan_vien_ids.user_id', '=', uid)]"/>
                <separator/>
                <filter string="Quá hạn" name="overdue" domain="[('date_deadline', '&lt;', context_today().strftime('%Y-%m-%d')), ('is_closed', '=', False)]"/>
                <filter string="Hôm nay" name="deadline_today" domain="[('date_deadline', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="Tuần này" name="deadline_week" domain="[('date_deadline', '&gt;=', context_today().strftime('%Y-%m-%d')), ('date_deadline', '&lt;=', (context_today() + datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter string="Đã hoàn thành" name="closed_tasks" domain="[('is_closed', '=', True)]"/>
                <filter string="Đang thực hiện" name="open_tasks" domain="[('is_closed', '=', False)]"/>
                
                <group expand="0" string="Gom nhóm theo...">
                    <filter string="Dự án" name="group_by_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Nhân viên thực hiện" name="group_by_employee" context="{'group_by': 'nhan_vien_ids'}"/>
                    <filter string="Hạn chót (Tháng)" name="group_by_deadline" context="{'group_by': 'date_deadline:month'}"/>
                    <filter string="Trạng thái" name="group_by_stage" context="{'group_by': 'stage_id'}"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- NEW Specialized Search View for Work Management (Includes Search Panel) -->
    <record id="view_task_search_hrm_with_panel" model="ir.ui.view">
        <field name="name">project.task.search.hrm.with.panel</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="view_task_search_inherit"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <searchpanel>
                    <field name="project_id" string="Dự án" icon="fa-folder" enable_counters="1"/>
                    <field name="stage_id" string="Trạng thái" icon="fa-tasks" enable_counters="1"/>
                </searchpanel>
            </xpath>
        </field>
    </record>
    
    <record id="view_task_tree_inherit" model="ir.ui.view">
        <field name="name">project.task.tree.inherit.quan_ly_cong_viec</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_tree2"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="decoration-success">is_closed == True</attribute>
                <attribute name="decoration-danger">date_deadline and date_deadline &lt; current_date and is_closed == False</attribute>
                <attribute name="decoration-warning">date_deadline and date_deadline == current_date and is_closed == False</attribute>
            </xpath>
            <xpath expr="//field[@name='user_ids']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='user_ids']" position="after">
                <field name="nhan_vien_ids" widget="many2many_tags" string="Nhân viên HRM"/>
                <field name="planned_date_begin" string="Bắt đầu"/>
                <field name="completion_percentage" widget="progressbar"/>
            </xpath>
        </field>
    </record>

    <record id="view_task_kanban_inherit" model="ir.ui.view">
        <field name="name">project.task.kanban.inherit.quan_ly_cong_viec</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//kanban" position="attributes">
                <attribute name="quick_create">false</attribute>
            </xpath>
            <xpath expr="//kanban" position="inside">
                <field name="project_id" invisible="1"/>
                <field name="nhan_vien_ids"/>
                <field name="completion_percentage"/>
                <field name="date_deadline"/>
            </xpath>
            <xpath expr="//field[@name='project_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            
            <!-- 1. Đầu thẻ: Trạng thái & KPI (Gọn) -->
            <xpath expr="//strong[hasclass('o_kanban_record_title')]" position="before">
                <field name="task_status_class" invisible="1"/>
                <field name="task_status_label" invisible="1"/>
                <div class="d-flex align-items-center mb-1" t-if="record.task_status_label.raw_value">
                    <span t-attf-class="badge #{record.task_status_class.raw_value}" style="font-size: 10px; padding: 2px 6px;">
                        <t t-esc="record.task_status_label.raw_value"/>
                    </span>
                    <span t-if="record.kpi_rating.raw_value" 
                          t-attf-class="badge ms-1 #{record.kpi_rating.raw_value == 'a' and 'bg-primary' or (record.kpi_rating.raw_value == 'b' and 'bg-info' or (record.kpi_rating.raw_value == 'c' and 'bg-warning' or 'bg-dark'))}" 
                          style="font-size: 10px; padding: 2px 6px;">
                        KPI: <field name="kpi_rating"/>
                    </span>
                </div>
            </xpath>

            <!-- 2. Thân thẻ: Tiêu đề & Dự án & Hạn chót (Dán khít) -->
            <xpath expr="//strong[hasclass('o_kanban_record_title')]" position="after">
                <div class="mt-0 mb-0" style="line-height: 1.1; font-size: 11px;">
                    <!-- Link Dự án -->
                    <button name="action_view_project_tasks" type="object" 
                            class="btn btn-link p-0 text-muted fw-normal" 
                            style="font-size: 11px; text-decoration: none; display: block;">
                        <field name="project_id" invisible="0"/>
                    </button>
                    <!-- Hạn chót -->
                    <div t-if="record.date_deadline.raw_value" 
                         t-attf-class="mt-1 #{record.date_deadline.raw_value &lt; new Date() ? 'text-danger fw-bold' : 'text-muted'}"
                         style="font-size: 10px;">
                        <field name="date_deadline"/>
                    </div>
                </div>
            </xpath>

            <!-- 3. XÓA BỎ TRIỆT ĐỂ o_kanban_record_body để triệt tiêu khoảng trắng -->
            <xpath expr="//div[hasclass('o_kanban_record_body')]" position="replace">
                <div class="d-none"/>
            </xpath>

            <!-- 4. Chân thẻ: Nhân viên & Tiến độ -->
            <xpath expr="//div[hasclass('o_kanban_record_bottom')]" position="before">
                <div class="mt-1 pt-1 border-top" style="font-size: 11px;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center flex-grow-1">
                            <field name="nhan_vien_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                        </div>
                        <div t-if="record.completion_percentage.raw_value > 0" style="width: 40px;" class="ms-2">
                             <field name="completion_percentage" widget="progressbar" style="height: 4px;"/>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

    <record id="action_generate_ai_from_task_menu" model="ir.actions.server">
        <field name="name">Nhờ AI Gợi Ý Công Việc</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="binding_model_id" ref="project.model_project_task"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            if records:
                action = records[0].action_generate_tasks_ai_from_task()
        </field>
    </record>

    <!-- Calendar View -->
    <record id="view_project_task_calendar_hrm" model="ir.ui.view">
        <field name="name">project.task.calendar.hrm</field>
        <field name="model">project.task</field>
        <field name="arch" type="xml">
            <calendar string="Lịch công việc" 
                      date_start="planned_date_begin" 
                      date_stop="date_deadline" 
                      color="stage_id" 
                      mode="month">
                <field name="name"/>
                <field name="project_id"/>
                <field name="nhan_vien_ids" widget="many2many_tags"/>
            </calendar>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_project_task_graph_hrm" model="ir.ui.view">
        <field name="name">project.task.graph.hrm</field>
        <field name="model">project.task</field>
        <field name="arch" type="xml">
            <graph string="Phân tích công việc" type="bar" sample="1">
                <field name="stage_id"/>
                <field name="project_id"/>
                <field name="completion_percentage" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_project_task_pivot_hrm" model="ir.ui.view">
        <field name="name">project.task.pivot.hrm</field>
        <field name="model">project.task</field>
        <field name="arch" type="xml">
            <pivot string="Bảng tổng hợp công việc" sample="1">
                <field name="project_id" type="row"/>
                <field name="stage_id" type="col"/>
                <field name="completion_percentage" type="measure"/>
            </pivot>
        </field>
    </record>

</odoo>
