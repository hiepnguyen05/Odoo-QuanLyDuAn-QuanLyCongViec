<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Form View: Mở rộng Form Công việc -->
    <record id="view_task_form_inherit" model="ir.ui.view">
        <field name="name">project.task.form.inherit.quan_ly_cong_viec</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='allow_subtasks']" position="before">
                <field name="company_id" invisible="1"/>
                <field name="project_id" invisible="1"/>
                <field name="parent_id" invisible="1"/>
            </xpath>
            
            <xpath expr="//field[@name='user_ids']" position="before">
                <div class="alert alert-warning" role="alert" 
                     attrs="{'invisible': [('project_id', '=', False)]}">
                    <strong>⚠️ Lưu ý phân quyền:</strong>
                    <p>Chỉ được gán công việc cho nhân viên thuộc dự án này.</p>
                </div>
            </xpath>
            <xpath expr="//field[@name='user_ids']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='user_ids']" position="after">
                <field name="nhan_vien_ids" widget="many2many_tags" options="{'no_create': True}" string="Nhân viên HRM"/>
                <field name="completion_percentage" widget="progressbar"/>
            </xpath>
            
            <xpath expr="//field[@name='date_deadline']" position="before">
                <field name="planned_date_begin" string="Ngày bắt đầu"/>
            </xpath>

            <xpath expr="//group" position="after">
                <group string="📊 Đánh giá kết quả (KPI)" name="kpi_data" 
                       attrs="{'invisible': [('date_completed', '=', False)]}">
                    <group>
                        <field name="date_completed"/>
                        <field name="kpi_rating" widget="priority"/>
                    </group>
                    <group>
                        <div class="alert alert-info" role="alert" style="margin-bottom: 0px;" 
                             attrs="{'invisible': [('kpi_rating', '=', False)]}">
                            <strong>💡 Cách tính:</strong> KPI được tự động xếp loại khi bạn chuyển công việc sang trạng thái Hoàn thành.
                        </div>
                    </group>
                </group>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page name="subtasks" string="Công việc con (Subtasks)">
                    <field name="child_ids" context="{'default_project_id': project_id, 'default_parent_id': id}">
                        <tree editable="bottom">
                            <field name="company_id" invisible="1"/>
                            <field name="project_id" invisible="1"/>
                            <field name="name" string="Tên Subtask"/>
                            <field name="nhan_vien_ids" widget="many2many_tags" string="Người thực hiện"/>
                            <field name="date_deadline" string="Hạn chót"/>
                            <field name="stage_id" string="Trạng thái"/>
                        </tree>
                    </field>
                </page>
                <page name="ai_guidance" string="Hướng dẫn AI &amp; Checklist">
                    <group>
                        <group string="Quy trình thực hiện (SOP)">
                            <field name="ai_sop" nolabel="1" placeholder="AI sẽ viết quy trình ở đây..."/>
                        </group>
                        <group string="Danh sách kiểm tra">
                            <field name="checklist_ids" nolabel="1">
                                <tree editable="bottom">
                                    <field name="is_done" widget="boolean_toggle"/>
                                    <field name="name"/>
                                </tree>
                            </field>
                        </group>
                    </group>
                </page>
            </xpath>
            
        </field>
    </record>
    
    <record id="view_task_search_inherit" model="ir.ui.view">
        <field name="name">project.task.search.inherit.quan_ly_cong_viec</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_search_form"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='my_tasks']" position="after">
                <separator/>
                <filter string="Việc của tôi (HRM)" 
                        name="my_tasks_hrm" 
                        domain="[('nhan_vien_ids.user_id', '=', uid)]"/>
                <filter string="Lọc theo Dự án" name="group_by_project" context="{'group_by': 'project_id'}"/>
                <filter string="Lọc theo Nhân viên" name="group_by_employee" context="{'group_by': 'nhan_vien_ids'}"/>
                <filter string="Lọc theo Trạng thái" name="group_by_stage" context="{'group_by': 'stage_id'}"/>
            </xpath>
        </field>
    </record>
    
    <record id="view_task_tree_inherit" model="ir.ui.view">
        <field name="name">project.task.tree.inherit.quan_ly_cong_viec</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_tree2"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="decoration-success">is_closed == True</attribute>
                <attribute name="decoration-danger">date_deadline and date_deadline &lt; current_date and is_closed == False</attribute>
                <attribute name="decoration-warning">date_deadline and date_deadline == current_date and is_closed == False</attribute>
            </xpath>
            <xpath expr="//field[@name='user_ids']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='user_ids']" position="after">
                <field name="nhan_vien_ids" widget="many2many_tags" string="Nhân viên HRM"/>
                <field name="planned_date_begin" string="Bắt đầu"/>
                <field name="completion_percentage" widget="progressbar"/>
            </xpath>
        </field>
    </record>

    <record id="view_task_kanban_inherit" model="ir.ui.view">
        <field name="name">project.task.kanban.inherit.quan_ly_cong_viec</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//kanban" position="attributes">
                <attribute name="quick_create">false</attribute>
            </xpath>
            <xpath expr="//kanban" position="inside">
                <field name="nhan_vien_ids"/>
                <field name="completion_percentage"/>
            </xpath>
            <xpath expr="//strong[hasclass('o_kanban_record_title')]" position="before">
                <field name="task_status_class" invisible="1"/>
                <field name="task_status_label" invisible="1"/>
                <div t-if="record.task_status_label.raw_value" style="margin-bottom: 5px;">
                    <span t-attf-class="badge #{record.task_status_class.raw_value}" style="font-size: 11px; padding: 4px 8px; border-radius: 4px;">
                        <t t-esc="record.task_status_label.raw_value"/>
                    </span>
                    <span t-if="record.kpi_rating.raw_value" 
                          t-attf-class="badge #{record.kpi_rating.raw_value == 'a' and 'bg-primary' or (record.kpi_rating.raw_value == 'b' and 'bg-info' or (record.kpi_rating.raw_value == 'c' and 'bg-warning' or 'bg-dark'))}" 
                          style="font-size: 11px; margin-left: 5px; padding: 4px 8px; border-radius: 4px;">
                        KPI: <field name="kpi_rating"/>
                    </span>
                </div>
            </xpath>
            <xpath expr="//div[hasclass('o_kanban_record_bottom')]" position="before">
                <div style="margin-top: 5px;">
                    <field name="completion_percentage" widget="progressbar"/>
                </div>
                <div style="margin-top: 8px; font-size: 12px; padding-top: 8px; border-top: 1px solid #eee;">
                    <strong class="text-muted"><i class="fa fa-user-circle-o"></i> HRM: </strong>
                    <field name="nhan_vien_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                </div>
            </xpath>
        </field>
    </record>

    <record id="action_generate_ai_from_task_menu" model="ir.actions.server">
        <field name="name">Nhờ AI Gợi Ý Cột &amp; Công Việc</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="binding_model_id" ref="project.model_project_task"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            if records:
                action = records[0].action_generate_tasks_ai_from_task()
        </field>
    </record>

</odoo>
